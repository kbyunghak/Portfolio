@{
    ViewBag.Title = "Home Page";
}

<div class="jumbotron" style="height:auto !important;">
    <div style="float: left; width: 50%;">
        <img src="~/Image/ak.png" style="height: 40%; width: 50%; object-fit: contain" />
        <p class="lead">
            
            Andrew Kim <br />
            Software Developer
        </p>
    </div>
    <div>
        <p>
            Organized and passionate software developer with expertise in design, installation, testing and
            maintenance of software systems. Fluent in C#, Java, ASP.NET MVC/ Core, SQL, JavaScript and CSS
            Programming languages. Able to effectively self-manage during independent projects, as well as
            collaborate as part of a productive team.
        </p>
    </div>   
    <p>
        <button id="btnResume" class="btn btn-primary btn-lg" onclick="showResume();">Show Andrew's Resume</button>
        <a href="https://www.linkedin.com/in/kbyunghak/" class="btn btn-primary btn-lg">Go To LinkedIn</a>
    </p>
    
    
</div>
<div id="resume" hidden>
    <object data="~/Image/AndrewKim_Resume.pdf" type="application/pdf" width="100%;" height="1000px;">
        <p>Alternative text - include a link <a href="~/Image/AndrewKim_Resume.pdf" style="height:auto !important;">to the PDF!</a></p>
    </object>
</div>
