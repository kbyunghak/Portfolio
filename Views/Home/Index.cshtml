<script>
    function showResume() {
        var btnName = $('#btnResume').text();
        if (btnName == "Hide Andrew's Resume") {
            $('#resume').hide();
            $('#btnResume').text("Show Andrew's Resume");
        } else {
            $('#resume').show();
            $('#btnResume').text("Hide Andrew's Resume");
        }
        
    }
</script>